# ==========================================================================
# Sysmax Sales Agent — variaveis de ambiente (TEMPLATE)
# Copie para .env e preencha. NUNCA versione o .env real.
# Este app e ISOLADO do produto VetMax: usa banco, numero e deploy proprios.
# ==========================================================================

# --- Supabase EXCLUSIVO da Sysmax (CRM corporativo, sem clinic_id) ---------
# Projeto NOVO no Supabase, separado do banco do VetMax.
SALES_SUPABASE_URL=
SALES_SUPABASE_SERVICE_KEY=
# Connection string Postgres (Settings > Database > Connection string > URI).
# Usada apenas por scripts/apply-migrations.mjs (DDL). Use o pooler 5432/6543.
SALES_DATABASE_URL=

# --- Anthropic (Claude) — pode reaproveitar as chaves da Sysmax ------------
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_FALLBACK=

# --- Evolution API (mesma VPS do VetMax, instancia DEDICADA) ---------------
EVOLUTION_API_URL=https://wpp.sysmaxsolutions.com
EVOLUTION_API_KEY=
# Instancia dedicada ao numero comercial Sysmax (criada na Fase 0).
EVOLUTION_COMMERCIAL_INSTANCE=sysmax-comercial
# Numero comercial que aparece no site institucional.
SYSMAX_COMMERCIAL_PHONE=5516997023340

# --- Meta Graph API (Instagram + Facebook) — Fase 2 ------------------------
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# --- Seguranca dos crons/webhooks ------------------------------------------
CRON_SECRET=
